---
import { navLinks } from "@/data/siteConfig";
import MobileNav from "./MobileNav.astro";
---
<header class="sticky top-0 z-40 border-b border-border bg-surface">
  <div class="mx-auto flex h-16 max-w-[1440px] items-center justify-between px-6 md:h-20 md:px-10 lg:px-[120px]">
    <a href="/" class="flex items-center gap-2 font-mono text-base font-semibold tracking-[0.15em] text-primary md:gap-2.5 md:text-lg md:tracking-[0.2em]" aria-label="Home - Treisy Jiménez">
      <span>TREISY JIMÉNEZ</span>
      <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
    </a>

    <!-- Desktop nav (tablet + desktop) -->
    <nav class="hidden items-center gap-8 md:flex lg:gap-10" aria-label="Main navigation">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-muted transition-colors hover:text-primary"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Desktop CTA -->
    <a
      href="#contact"
      class="hidden items-center rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-surface transition-opacity hover:opacity-90 md:inline-flex md:px-6 md:py-3"
    >
      Book a Call
    </a>

    <!-- Mobile menu button -->
    <button
      type="button"
      id="mobile-nav-open"
      class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg border border-border-light text-muted transition-colors hover:bg-surface-elevated hover:text-primary focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-surface active:bg-surface-elevated md:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>

<MobileNav />
