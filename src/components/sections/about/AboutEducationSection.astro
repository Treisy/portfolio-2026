---
import type { Content } from "@/types";
import type { Education } from "@/types";

interface Props {
  about: NonNullable<Content["about"]>;
  education: Education[];
}
const { about, education } = Astro.props;
const { label, title, subtitle } = about.education;
---
<section class="bg-surface px-5 py-14 md:px-10 md:py-16 lg:px-[120px] lg:py-[100px]" aria-labelledby="about-edu-title">
  <div class="mx-auto max-w-[1440px] flex flex-col gap-8 md:gap-10 lg:gap-16">
    <header class="flex flex-col items-center gap-4 text-center">
      <p class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-accent">{label}</p>
      <h2 id="about-edu-title" class="font-serif text-3xl font-normal text-primary md:text-4xl lg:text-[42px]">
        {title}
      </h2>
      <p class="max-w-[550px] text-base text-subtle">{subtitle}</p>
    </header>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 md:gap-6">
      {education.map((edu) => (
        <article
          class={`rounded-2xl border p-5 md:p-8 flex flex-col gap-4 ${
            edu.inProgress ? "border-accent/30 bg-surface-elevated" : "border-border bg-surface-elevated"
          }`}
          aria-labelledby={`edu-${edu.id}-degree`}
        >
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-accent/20 text-accent md:h-10 md:w-10">
            {edu.degree === "MBA" ? (
              <svg class="h-5 w-5 md:h-8 md:w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            ) : (
              <svg class="h-5 w-5 md:h-8 md:w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
              </svg>
            )}
          </div>
          <h3 id={`edu-${edu.id}-degree`} class="font-serif text-lg font-normal text-primary md:text-xl">
            {edu.degree}
          </h3>
          <p class="font-mono text-xs font-medium text-accent md:text-sm">{edu.degreeTitle}</p>
          <p class="text-sm text-muted">{edu.institution}</p>
          <p class="text-[13px] text-subtle">
            {edu.inProgress ? (
              <span class="inline-flex items-center gap-1.5 rounded-full bg-accent/10 px-2.5 py-1 font-mono text-xs font-medium text-accent">
                <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
                In Progress
              </span>
            ) : (
              `${edu.startYear} - ${edu.endYear ?? "Present"}`
            )}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
