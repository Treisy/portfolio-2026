---
import { getContent } from "@/lib/data/content";
const content = await getContent();
const { services } = content;
---
<section id="services" class="bg-surface-elevated px-6 py-16 sm:py-20 md:px-10 md:py-24 lg:px-[120px] lg:py-[100px]" aria-labelledby="services-title">
  <div class="mx-auto max-w-[1440px]">
    <div class="mb-12 flex flex-col items-center gap-3 text-center sm:mb-16 sm:gap-4">
      <p class="font-mono text-xs font-medium uppercase tracking-[0.3em] text-accent">{services.label}</p>
      <h2 id="services-title" class="font-serif text-2xl font-normal text-primary sm:text-3xl md:text-4xl lg:text-[42px]">
        {services.title}
      </h2>
      <p class="max-w-[600px] text-sm text-subtle sm:text-base">
        {services.subtitle}
      </p>
    </div>
    <div class="grid grid-cols-1 gap-5 sm:gap-6 md:grid-cols-2 md:px-0 lg:grid-cols-3 lg:gap-6">
      {
        services.items.map((service) => (
          <article class="rounded-2xl border border-border bg-surface p-6 transition-colors hover:border-border-light sm:p-8">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-accent/10 sm:mb-5 sm:h-14 sm:w-14">
              <span class="text-lg font-semibold text-accent sm:text-xl" aria-hidden="true">
                {service.icon === "scrum" ? "◇" : service.icon === "pm" ? "▣" : "{}"}
              </span>
            </div>
            <h3 class="mb-3 text-lg font-semibold text-primary sm:mb-4 sm:text-xl">{service.title}</h3>
            <p class="text-[14px] leading-relaxed text-subtle sm:text-[15px]">{service.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
