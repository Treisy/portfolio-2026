---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import { getPostBySlug, getPosts } from "@/lib/data/blog";
import { getContent } from "@/lib/data/content";
import { siteConfig } from "@/data/siteConfig";

export async function getStaticPaths() {
  const posts = await getPosts();
  const slugs = posts.filter((p) => p.slug).map((p) => p.slug!);
  return slugs.map((slug) => ({ params: { slug }, props: {} }));
}

interface Props {
  slug: string;
}
const { slug } = Astro.params;
const post = slug ? await getPostBySlug(slug) : undefined;

if (!post) {
  return Astro.redirect("/404");
}

const content = await getContent();
const allPosts = await getPosts();
const detail = content.blogDetail ?? {
  backLabel: "Back to Blog",
  tagsLabel: "Tags:",
  shareLabel: "Share:",
};
const blogHref = content.blog.viewAllHref;
const currentIndex = allPosts.findIndex((p) => p.slug === post.slug);
const prevPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const nextPost = currentIndex >= 0 && currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;

const title = post.title;
const description = post.excerpt.slice(0, 160);
const ogImage = post.image?.startsWith("http") ? post.image : post.image ? `${Astro.url.origin}${post.image}` : undefined;
const hasBody = post.body && post.body.length > 0;
const tags = [post.category].filter(Boolean) as string[];
---
<BaseLayout title={title} description={description} image={ogImage} type="article">
  <Header />

  <main id="main-content" class="min-h-screen bg-surface">
    <!-- Article Hero (Pencil: ArticleHero) - mobile: compact, tablet: 48/60, desktop: 60/120 -->
    <section class="px-5 pt-8 pb-6 md:px-10 md:pt-12 md:pb-8 lg:px-[120px] lg:pt-16 lg:pb-10" aria-labelledby="article-title">
      <div class="mx-auto max-w-[1440px]">
        <a
          href={blogHref}
          class="mb-6 inline-flex items-center gap-2 text-[13px] font-medium text-subtle transition-colors hover:text-primary md:mb-8"
        >
          <svg class="h-3.5 w-3.5 shrink-0 md:h-4 md:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {detail.backLabel}
        </a>
        <div class="flex flex-col gap-5 md:gap-6">
          {post.category && (
            <span class="w-fit rounded-full bg-accent/10 px-3 py-1.5 font-mono text-[11px] font-medium uppercase tracking-wider text-accent">
              {post.category}
            </span>
          )}
          <h1 id="article-title" class="font-serif text-[28px] font-normal leading-tight text-primary md:text-3xl lg:text-[36px] xl:text-[42px]">
            {post.title}
          </h1>
          <div class="flex items-center gap-3">
            <div class="h-9 w-9 shrink-0 rounded-full bg-surface-elevated border border-border flex items-center justify-center text-accent font-serif text-sm font-medium" aria-hidden="true">
              {siteConfig.name.charAt(0)}
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-sm font-medium text-primary">{siteConfig.name}</span>
              {post.date && <span class="text-xs text-subtle">{post.date}</span>}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Hero Image (Pencil: HeroImage) - mobile: 240, tablet: 360, desktop: 420 -->
    {post.image ? (
      <section class="px-0 md:px-10 lg:px-[120px]" aria-hidden="true">
        <div class="mx-auto max-w-[1440px]">
          <div class="overflow-hidden rounded-none bg-surface-elevated md:rounded-2xl">
            <img
              src={post.image}
              alt=""
              width={1440}
              height={420}
              sizes="100vw"
              class="h-60 w-full object-cover object-center md:h-[360px] lg:h-[420px]"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
      </section>
    ) : (
      <section class="px-5 md:px-10 lg:px-[120px]" aria-hidden="true">
        <div class="mx-auto max-w-[1440px]">
          <div class="flex h-60 items-center justify-center rounded-xl bg-surface-elevated border border-border md:h-[360px] lg:h-[420px] text-subtle/50">
            <svg class="h-16 w-16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6m4-4h-1m-1 4h2m-4 0H9m-2 0h2" /></svg>
          </div>
        </div>
      </section>
    )}

    <!-- Article Body (Pencil: ArticleBody) -->
    <article class="px-5 py-8 md:px-10 md:py-12 lg:px-[120px] lg:py-16">
      <div class="mx-auto max-w-[800px]">
        {hasBody ? (
          <div class="flex flex-col gap-6 md:gap-7">
            {post.body!.map((block, i) => {
              if (block.type === "h2") {
                return (
                  <h2 id={`section-${i}`} class="font-serif text-xl font-normal text-primary md:text-2xl">
                    {block.text}
                  </h2>
                );
              }
              if (block.type === "quote") {
                return (
                  <blockquote class="border-l-4 border-accent pl-5 pr-0 py-0 flex flex-col gap-2 md:pl-6">
                    <p class="font-serif text-base italic leading-relaxed text-primary md:text-lg">
                      &ldquo;{block.text}&rdquo;
                    </p>
                    {block.attribution && (
                      <cite class="font-mono text-xs font-medium text-accent not-italic">
                        — {block.attribution}
                      </cite>
                    )}
                  </blockquote>
                );
              }
              return (
                <p class="text-[15px] leading-[1.8] text-muted md:text-base">
                  {block.text}
                </p>
              );
            })}
          </div>
        ) : (
          <p class="text-[15px] leading-[1.8] text-muted md:text-base">
            {post.excerpt}
          </p>
        )}
      </div>
    </article>

    <!-- Share Bar (Pencil: ShareBar) -->
    <section class="border-y border-border bg-surface px-5 py-6 md:px-10 lg:px-[120px]" aria-label={detail.shareLabel}>
      <div class="mx-auto flex max-w-[1440px] flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex flex-wrap items-center gap-2 sm:gap-3">
          <span class="text-xs font-medium text-subtle">{detail.tagsLabel}</span>
          {tags.map((tag) => (
            <span class="rounded-full bg-accent/10 px-2.5 py-1 font-mono text-[11px] font-medium text-accent">
              {tag}
            </span>
          ))}
        </div>
        <div class="flex items-center gap-3">
          <span class="text-xs font-medium text-subtle">{detail.shareLabel}</span>
          <div class="flex items-center gap-3">
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted transition-colors hover:text-primary"
              aria-label="Share on Twitter"
            >
              <svg class="h-4 w-4 md:h-[18px] md:w-[18px]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted transition-colors hover:text-primary"
              aria-label="Share on LinkedIn"
            >
              <svg class="h-4 w-4 md:h-[18px] md:w-[18px]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
            <button
              type="button"
              class="text-muted transition-colors hover:text-primary"
              aria-label="Copy link"
              data-copy-link
            >
              <svg class="h-4 w-4 md:h-[18px] md:w-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Prev/Next (optional, like project detail) -->
    <nav class="border-t border-border bg-surface px-5 py-8 md:px-10 lg:px-[120px] lg:py-10" aria-label="More articles">
      <div class="mx-auto flex max-w-[1440px] flex-col gap-6 sm:flex-row sm:justify-between sm:gap-8">
        {prevPost?.slug ? (
          <a href={`/blog/${prevPost.slug}`} class="group flex items-center gap-4 text-left">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-border-light text-subtle transition-colors group-hover:border-accent group-hover:text-accent">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            </span>
            <div class="min-w-0">
              <span class="block text-xs font-medium uppercase tracking-wider text-subtle">Previous</span>
              <span class="mt-0.5 block truncate font-medium text-primary group-hover:text-accent">{prevPost.title}</span>
            </div>
          </a>
        ) : (
          <span />
        )}
        {nextPost?.slug ? (
          <a href={`/blog/${nextPost.slug}`} class="group flex items-center gap-4 text-right sm:flex-row-reverse">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-border-light text-subtle transition-colors group-hover:border-accent group-hover:text-accent">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
            <div class="min-w-0 text-right sm:text-right">
              <span class="block text-xs font-medium uppercase tracking-wider text-subtle">Next</span>
              <span class="mt-0.5 block truncate font-medium text-primary group-hover:text-accent">{nextPost.title}</span>
            </div>
          </a>
        ) : (
          <span />
        )}
      </div>
    </nav>
  </main>

  <Footer />

  <script>
    document.querySelector("[data-copy-link]")?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const btn = document.querySelector("[data-copy-link]");
        if (btn) {
          const label = btn.getAttribute("aria-label");
          btn.setAttribute("aria-label", "Link copied!");
          setTimeout(() => btn.setAttribute("aria-label", label ?? "Copy link"), 2000);
        }
      } catch (_) {}
    });
  </script>
</BaseLayout>
