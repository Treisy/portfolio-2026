---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import { getProjectBySlug, getProjects } from "@/lib/data/projects";
import { getContent } from "@/lib/data/content";

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

interface Props {
  project: Awaited<ReturnType<typeof getProjectBySlug>>;
}
const { project } = Astro.props;

if (!project) {
  return Astro.redirect("/404");
}

const content = await getContent();
const allProjects = await getProjects();
const detail = content.projectDetail ?? {
  backLabel: "All projects",
  breadcrumbPortfolio: "Portfolio",
  viewLiveLabel: "View live",
  githubLabel: "GitHub",
  roleLabel: "Role",
  yearLabel: "Year",
  techStackLabel: "Tech stack",
  overviewLabel: "OVERVIEW",
  challengeTitle: "The Challenge",
  roleSectionLabel: "MY ROLE",
  resultsLabel: "RESULTS",
  resultsTitle: "Impact & Achievements",
  processLabel: "PROCESS",
  processTitle: "How I Approached It",
  galleryLabel: "GALLERY",
  galleryTitle: "Project Screenshots",
  moreProjectsLabel: "More projects",
  prevLabel: "Previous",
  nextLabel: "Next",
};

const currentIndex = allProjects.findIndex((p) => p.slug === project.slug);
const prevProject = currentIndex > 0 ? allProjects[currentIndex - 1] : null;
const nextProject = currentIndex >= 0 && currentIndex < allProjects.length - 1 ? allProjects[currentIndex + 1] : null;

const title = project.title;
const description = project.description.slice(0, 160);
const ogImage = project.image.src.startsWith("http") ? project.image.src : `${Astro.url.origin}${project.image.src}`;
const portfolioHref = content.portfolio.viewAllHref;

const hasOverview = project.challenge ?? project.roleDescription;
const hasResults = project.results && project.results.length > 0;
const hasProcess = project.processSteps && project.processSteps.length > 0;
const hasGallery = project.galleryImages && project.galleryImages.length > 0;
---
<BaseLayout title={title} description={description} image={ogImage} type="article">
  <Header />

  <main id="main-content" class="min-h-screen bg-surface">
    <!-- Project Hero (Pencil: Project Hero) -->
    <section class="px-5 py-12 md:px-10 md:py-16 lg:px-[120px] lg:py-[60px] lg:pb-20" aria-labelledby="project-title">
      <div class="mx-auto max-w-[1440px]">
        <nav class="mb-6 flex items-center gap-2 text-sm text-subtle md:mb-10" aria-label="Breadcrumb">
          <a href={portfolioHref} class="font-medium hover:text-primary">{detail.breadcrumbPortfolio}</a>
          <svg class="h-4 w-4 shrink-0 md:h-4 md:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
          <span class="font-medium text-accent" aria-current="page">{project.title}</span>
        </nav>
        <div class="flex flex-col gap-6 md:gap-8">
          {project.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="rounded-md bg-surface-elevated px-3 py-1 text-xs font-medium text-muted">{tag}</span>
              ))}
            </div>
          )}
          <h1 id="project-title" class="font-serif text-[28px] font-normal leading-tight text-primary md:text-4xl lg:text-[52px]">
            {project.title}
          </h1>
          <p class="max-w-[800px] text-sm leading-relaxed text-muted md:text-lg">
            {project.longDescription ?? project.description}
          </p>
          <div class="flex flex-wrap items-center gap-6 text-sm text-subtle">
            {project.role && <span><span class="font-medium text-muted">{detail.roleLabel}:</span> {project.role}</span>}
            {project.year && <span><span class="font-medium text-muted">{detail.yearLabel}:</span> {project.year}</span>}
            {project.company && <span>{project.company}</span>}
            {project.techStack.length > 0 && (
              <span class="flex flex-wrap gap-2">
                {project.techStack.slice(0, 3).map((tech) => (
                  <span class="rounded bg-surface-elevated px-2 py-0.5 text-xs text-muted">{tech}</span>
                ))}
              </span>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- Project Image (Pencil: full width, rounded) -->
    <section class="px-0 py-0 md:px-[120px] md:py-0" aria-hidden="true">
      <div class="mx-auto max-w-[1440px]">
        <div class="overflow-hidden rounded-none bg-surface-elevated md:rounded-2xl">
          <img
            src={project.image.src}
            alt={project.image.alt}
            width={1440}
            height={500}
            sizes="100vw"
            class="h-auto w-full object-cover object-center md:max-h-[500px]"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </section>

    <!-- Overview Section (Pencil: two columns - Challenge + My Role) -->
    {hasOverview && (
      <section class="bg-surface px-5 py-14 md:px-10 md:py-20 lg:px-[120px] lg:py-[100px]" aria-labelledby="overview-title">
        <div class="mx-auto max-w-[1440px] flex flex-col gap-10 lg:flex-row lg:gap-20">
          <div class="min-w-0 flex-1">
            <p class="mb-4 font-mono text-xs font-medium uppercase tracking-[0.2em] text-accent">{detail.overviewLabel}</p>
            <h2 id="overview-title" class="mb-6 font-serif text-2xl font-normal text-primary md:text-3xl lg:text-[36px]">
              {detail.challengeTitle}
            </h2>
            <p class="text-base leading-relaxed text-muted md:leading-[1.7]">
              {project.challenge ?? project.longDescription ?? project.description}
            </p>
          </div>
          {project.roleDescription && (
            <div class="shrink-0 lg:w-[400px]">
              <p class="mb-4 font-mono text-xs font-medium uppercase tracking-[0.2em] text-accent">{detail.roleSectionLabel}</p>
              <p class="text-base leading-relaxed text-muted md:leading-[1.7]">
                {project.roleDescription}
              </p>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Results Section (Pencil: impact cards grid) -->
    {hasResults && (
      <section class="bg-surface-elevated px-5 py-14 md:px-10 md:py-20 lg:px-[120px] lg:py-[100px]" aria-labelledby="results-title">
        <div class="mx-auto max-w-[1440px]">
          <header class="mb-10 flex flex-col items-center gap-4 text-center md:mb-16">
            <p class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-accent">{detail.resultsLabel}</p>
            <h2 id="results-title" class="font-serif text-3xl font-normal text-primary md:text-4xl lg:text-[42px]">
              {detail.resultsTitle}
            </h2>
          </header>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6">
            {project.results!.map((r) => (
              <div class="flex flex-col items-center justify-center gap-3 rounded-2xl border border-border bg-surface p-6 text-center md:p-10 md:gap-4 first:border-accent/30">
                <span class="font-serif text-2xl font-normal text-accent md:text-3xl">{r.value}</span>
                {r.label && <span class="text-sm text-muted md:text-base">{r.label}</span>}
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Process Section (Pencil: step cards) -->
    {hasProcess && (
      <section class="bg-surface px-5 py-14 md:px-10 md:py-20 lg:px-[120px] lg:py-[100px]" aria-labelledby="process-title">
        <div class="mx-auto max-w-[1440px]">
          <header class="mb-10 flex flex-col items-center gap-4 text-center md:mb-16">
            <p class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-accent">{detail.processLabel}</p>
            <h2 id="process-title" class="font-serif text-3xl font-normal text-primary md:text-4xl lg:text-[42px]">
              {detail.processTitle}
            </h2>
          </header>
          <div class="grid gap-6 md:gap-8">
            {project.processSteps!.map((step) => (
              <article class="rounded-2xl border border-border bg-surface-elevated p-6 md:p-8" aria-labelledby={`step-${step.step}-title`}>
                <div class="flex flex-col gap-4 md:gap-5">
                  <div class="flex items-center gap-3">
                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-accent/20 font-mono text-sm font-medium text-accent">
                      {step.step}
                    </span>
                    <h3 id={`step-${step.step}-title`} class="font-serif text-xl font-normal text-primary md:text-2xl">
                      {step.title}
                    </h3>
                  </div>
                  <p class="text-base leading-relaxed text-muted md:leading-[1.7]">{step.description}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Gallery Section (Pencil: project screenshots) -->
    {hasGallery && (
      <section class="bg-surface-elevated px-5 py-14 md:px-10 md:py-20 lg:px-[120px] lg:py-[100px]" aria-labelledby="gallery-title">
        <div class="mx-auto max-w-[1440px]">
          <header class="mb-10 flex flex-col items-center gap-4 text-center md:mb-12">
            <p class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-accent">{detail.galleryLabel}</p>
            <h2 id="gallery-title" class="font-serif text-3xl font-normal text-primary md:text-4xl lg:text-[42px]">
              {detail.galleryTitle}
            </h2>
          </header>
          <div class="grid gap-6 sm:grid-cols-2 lg:gap-8">
            {project.galleryImages!.map((img) => (
              <div class="overflow-hidden rounded-2xl border border-border bg-surface">
                <img
                  src={img.src}
                  alt={img.alt}
                  width={640}
                  height={360}
                  sizes="(max-width: 768px) 100vw, 50vw"
                  class="h-auto w-full object-cover object-center"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTAs (when no case-study sections: show simple block) -->
    {!hasOverview && !hasResults && !hasProcess && !hasGallery && (
      <section class="bg-surface px-5 py-14 md:px-10 md:py-20 lg:px-[120px]">
        <div class="mx-auto max-w-[900px]">
          <p class="text-base leading-relaxed text-muted md:text-lg">
            {project.longDescription ?? project.description}
          </p>
          {project.techStack.length > 0 && (
            <div class="mt-8">
              <h2 class="mb-3 font-mono text-xs font-medium uppercase tracking-wider text-accent">{detail.techStackLabel}</h2>
              <div class="flex flex-wrap gap-2">
                {project.techStack.map((tech) => (
                  <span class="rounded-lg border border-border bg-surface-elevated px-3 py-1.5 text-sm text-primary">{tech}</span>
                ))}
              </div>
            </div>
          )}
          <div class="mt-10 flex flex-wrap gap-4">
            {project.liveUrl && (
              <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-surface hover:opacity-90">
                {detail.viewLiveLabel}
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
              </a>
            )}
            {project.githubUrl && (
              <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-border-light px-6 py-3 text-sm font-semibold text-primary hover:bg-surface-elevated">
                {detail.githubLabel}
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
              </a>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- When case-study sections exist, show CTAs after gallery -->
    {(hasOverview || hasResults || hasProcess || hasGallery) && (project.liveUrl || project.githubUrl) && (
      <section class="bg-surface px-5 py-10 md:px-10 lg:px-[120px]">
        <div class="mx-auto max-w-[1440px] flex flex-wrap gap-4">
          {project.liveUrl && (
            <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-surface hover:opacity-90">
              {detail.viewLiveLabel}
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </a>
          )}
          {project.githubUrl && (
            <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-border-light px-6 py-3 text-sm font-semibold text-primary hover:bg-surface-elevated">
              {detail.githubLabel}
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </a>
          )}
        </div>
      </section>
    )}

    <!-- Navigation Section (Pencil: Prev / Next) -->
    <nav class="border-t border-border bg-surface px-5 py-8 md:px-10 md:py-10 lg:px-[120px] lg:py-[60px]" aria-label={detail.moreProjectsLabel}>
      <div class="mx-auto flex max-w-[1440px] flex-col gap-6 sm:flex-row sm:justify-between sm:gap-8">
        {prevProject ? (
          <a href={`/projects/${prevProject.slug}`} class="group flex items-center gap-4 text-left">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-border-light text-subtle transition-colors group-hover:border-accent group-hover:text-accent">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            </span>
            <div class="min-w-0">
              <span class="block text-xs font-medium uppercase tracking-wider text-subtle">{detail.prevLabel}</span>
              <span class="mt-0.5 block truncate font-medium text-primary group-hover:text-accent">{prevProject.title}</span>
            </div>
          </a>
        ) : (
          <span />
        )}
        {nextProject ? (
          <a href={`/projects/${nextProject.slug}`} class="group flex items-center gap-4 text-right sm:flex-row-reverse">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-border-light text-subtle transition-colors group-hover:border-accent group-hover:text-accent">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
            <div class="min-w-0 text-right sm:text-right">
              <span class="block text-xs font-medium uppercase tracking-wider text-subtle">{detail.nextLabel}</span>
              <span class="mt-0.5 block truncate font-medium text-primary group-hover:text-accent">{nextProject.title}</span>
            </div>
          </a>
        ) : (
          <span />
        )}
      </div>
    </nav>
  </main>

  <Footer />
</BaseLayout>
