---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import HeroSection from "@/components/sections/HeroSection.astro";
import ServicesSection from "@/components/sections/ServicesSection.astro";
import PortfolioSection from "@/components/sections/PortfolioSection.astro";
import BlogSection from "@/components/sections/BlogSection.astro";
import ContactSection from "@/components/sections/ContactSection.astro";

const title = "Home";
const description =
  "Treisy Jiménez — Certified Scrum Master, Project Manager, and Web Developer. Turning ideas into successful digital products. Based in Costa Rica.";
---
<BaseLayout title={title} description={description}>
  <Header />
  <main id="main-content">
    <HeroSection />
    <ServicesSection />
    <PortfolioSection />
    <BlogSection />
    <ContactSection />
  </main>
  <Footer />
</BaseLayout>
