## TYPESCRIPT RULES

- Always use explicit types. NEVER use `any`.
- Define all interfaces in `src/types/index.ts` or domain-specific files under `src/types/`.
- Use `type` for simple types and unions, `interface` for objects that may be extended.
- Astro component props always use `interface Props { ... }` inside the frontmatter.
- Use the `satisfies` operator when appropriate.
- Export all types from `src/types/index.ts` as barrel exports.
- Type all data shapes to match the future Django REST API response structure.

```typescript
// ✅ Correct
interface Props {
  title: string;
  description?: string;
  variant: 'primary' | 'secondary';
}

// ❌ Incorrect
const { title, description, variant } = Astro.props as any;
```

### Core types (define these first in src/types/index.ts):

```typescript
export interface Project {
  id: number;
  slug: string;
  title: string;
  description: string;    // max 160 chars for SEO
  longDescription?: string;
  techStack: string[];
  tags: string[];
  featured: boolean;
  image: { src: string; alt: string };
  liveUrl?: string;
  githubUrl?: string;
  role: string;
  company?: string;
  year: number;
}

export interface WorkExperience {
  id: number;
  company: string;
  role: string;
  startDate: string;      // ISO format: "2018-03"
  endDate?: string;       // undefined = current position
  description: string;
  highlights: string[];
  techStack: string[];
}

export interface Skill {
  name: string;
  category: 'frontend' | 'backend' | 'devops' | 'management' | 'tools';
  level: 'expert' | 'proficient' | 'familiar';
}

export interface Certification {
  name: string;
  issuer: string;
  year: number;
  credentialUrl?: string;
  badgeImage?: string;
}

export interface SiteConfig {
  name: string;
  title: string;
  description: string;
  siteUrl: string;
  social: {
    github?: string;
    linkedin?: string;
    email: string;
  };
}
```

