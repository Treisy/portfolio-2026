        {
          "type": "frame",
          "id": "G6CQX",
          "name": "ArticleBody",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 28,
          "padding": [
            48,
            60
          ],
          "children": [
            {
              "type": "text",
              "id": "Vo9bg",
              "fill": "#FFFFFF",
              "content": "The Agile Promise vs Reality",
              "fontFamily": "Instrument Serif",
              "fontSize": 24,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "60cUH",
              "fill": "#ADADB0",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Organizations worldwide have embraced agile methodologies with the promise of faster delivery, better quality, and happier teams. Yet study after study shows that a significant percentage of agile transformations fail to achieve their goals.",
              "lineHeight": 1.8,
              "fontFamily": "Inter",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "aykiV",
              "name": "quoteT",
              "width": "fill_container",
              "stroke": {
                "thickness": {
                  "left": 3
                },
                "fill": "#D4AF37"
              },
              "layout": "vertical",
              "gap": 10,
              "padding": [
                0,
                0,
                0,
                20
              ],
              "children": [
                {
                  "type": "text",
                  "id": "rHG2g",
                  "fill": "#FFFFFF",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "\"Agile is not a methodology. It's a mindset. You can't install a mindset — you have to grow one.\"",
                  "lineHeight": 1.5,
                  "fontFamily": "Instrument Serif",
                  "fontSize": 18,
                  "fontWeight": "normal",
                  "fontStyle": "italic"
                },
                {
                  "type": "text",
                  "id": "XQx6E",
                  "fill": "#D4AF37",
                  "content": "— Jeff Sutherland",
                  "fontFamily": "DM Mono",
                  "fontSize": 12,
                  "fontWeight": "500"
                }
              ]
            },
            {
              "type": "text",
              "id": "8zcQZ",
              "fill": "#FFFFFF",
              "content": "The Three Pillars of Successful Transformation",
              "fontFamily": "Instrument Serif",
              "fontSize": 24,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "ntndY",
              "fill": "#ADADB0",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Through my experience, I've identified three critical pillars that must be in place for an agile transformation to succeed. Missing even one of these creates significant risk of failure.",
              "lineHeight": 1.8,
              "fontFamily": "Inter",
              "fontSize": 15,
              "fontWeight": "normal"
            }
          ]
        },
