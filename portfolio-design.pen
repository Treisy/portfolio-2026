                    6,
                    14
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "ICOP3",
                      "fill": "#D4AF37",
                      "content": "Agile",
                      "fontFamily": "DM Mono",
                      "fontSize": 12,
                      "fontWeight": "500"
                    }
                  ]
                }
              ]
            },
            {
              "type": "text",
              "id": "JdMAp",
              "fill": "#FFFFFF",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Why Agile Transformations Fail — And How to Fix Them",
              "lineHeight": 1.15,
              "fontFamily": "Instrument Serif",
              "fontSize": 48,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "iyazb",
              "fill": "#ADADB0",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Most agile transformations stall because organizations focus on ceremonies instead of mindset shifts. Here's a practical framework for lasting change.",
              "lineHeight": 1.6,
              "fontFamily": "Inter",
              "fontSize": 18,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "tsNIA",
              "name": "AuthorRow",
              "width": "fill_container",
