                {
                  "type": "text",
                  "id": "dETSL",
                  "name": "quoteText",
                  "fill": "#FFFFFF",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "\"The organizations that thrive in the digital age are not those with the biggest budgets, but those with the greatest agility.\"",
                  "lineHeight": 1.6,
                  "fontFamily": "Instrument Serif",
                  "fontSize": 15,
