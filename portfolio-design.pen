          ],
          "children": [
            {
              "type": "text",
              "id": "T8I92",
              "name": "Intro Paragraph",
              "fill": "#ADADB0",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "In today's fast-paced digital landscape, the intersection of Agile methodology and digital transformation has become a critical focal point for organizations seeking to remain competitive. As someone who has guided multiple organizations through this journey, I've seen firsthand how the right approach can make all the difference.",
              "lineHeight": 1.7,
              "fontFamily": "Inter",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "QhcsL",
              "name": "Heading 1",
              "fill": "#FFFFFF",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "The Foundation of Agile Transformation",
              "lineHeight": 1.3,
              "fontFamily": "Instrument Serif",
              "fontSize": 20,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "jrlUK",
              "name": "Paragraph 1",
              "fill": "#ADADB0",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Successful digital transformation isn't just about adopting new technologies — it's about fundamentally changing how your organization thinks, operates, and delivers value. Agile provides the framework for this shift, enabling teams to iterate quickly, respond to change, and continuously improve.",
              "lineHeight": 1.7,
              "fontFamily": "Inter",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "cBehp",
              "name": "Blockquote",
              "width": "fill_container",
              "fill": "#18181B",
              "gap": 16,
              "padding": [
